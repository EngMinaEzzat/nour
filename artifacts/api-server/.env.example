# Optional: store product images on Cloudinary (HTTPS URLs work on any host; no local disk).
# Get these from Cloudinary Dashboard → Account Details / API Keys.
# If unset, uploads stay on the API server under /api/uploads/ (fine for local dev with proxy).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional folder prefix in Cloudinary Media Library (default: nour/products)
# CLOUDINARY_UPLOAD_FOLDER=nour/products
