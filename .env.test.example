# Copy this file to `.env.test`.
# `.env.test` is intentionally ignored because it contains real connection strings.

# Temporary local/shared test database.
# This may point at the current Supabase/dev database while there are no real merchants.
DATABASE_URL=postgres://user:pass@host:6543/postgres?pgbouncer=true

# Test-only secrets and provider mocks.
SESSION_SECRET=test-only-secret-not-for-production
PAYMOB_ALLOW_MOCKS=true
AI_USE_MOCK=true

# Intentional escape hatch:
# Allows destructive API tests to run even when DATABASE_URL does not include
# localhost, _test, -test, test_, or localtest.
#
# Keep this true only while the configured database contains no real merchant,
# customer, order, or payment data. Before production/onboarding real users,
# create a dedicated test/staging database and remove this override.
MATJAREG_TEST_DATABASE_OK=true
